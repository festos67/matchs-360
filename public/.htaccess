# ============================================================
# matchs-360 — configuration Apache (OVH mutualisé)
# Headers de sécurité + redirection HTTPS + fallback SPA.
# ============================================================

# --- 1. Forcer HTTPS (doit précéder le fallback SPA) ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# --- 2. Fallback SPA : routes inconnues -> index.html (React Router) ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Ne pas réécrire les fichiers et dossiers réellement présents (assets…)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Tout le reste -> index.html
  RewriteRule ^ index.html [L]
</IfModule>

# --- 3. Headers de sécurité (auparavant servis par Cloudflare/Lovable) ---
<IfModule mod_headers.c>
  # HSTS : forcer HTTPS 2 ans, sous-domaines inclus, éligible preload.
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  # Anti-clickjacking (legacy ; la CSP frame-ancestors 'none' couvre les navigateurs récents).
  Header always set X-Frame-Options "DENY"
  # Anti MIME-sniffing.
  Header always set X-Content-Type-Options "nosniff"
  # Référent minimal inter-origines.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Réduire la surface d'API navigateur.
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- 4. Cache ---
<IfModule mod_headers.c>
  # index.html jamais mis en cache : chaque déploiement prend effet immédiatement.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  # Assets hashés par Vite : cache long immuable.
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|gif|svg|webp|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# --- 5. Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# --- 6. Refuser l'accès aux fichiers sensibles éventuellement déployés ---
<FilesMatch "^\.(env|git)">
  Require all denied
</FilesMatch>